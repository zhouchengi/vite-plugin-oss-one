{
  "name": "vite-plugin-oss-one",
  "version": "1.1.4",
  "description": "A lightweight, extensible Vite plugin to automatically upload build artifacts to Object Storage Services (OSS).",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhouchengi/vite-plugin-oss-one.git"
  },
  "bugs": {
    "url": "https://github.com/zhouchengi/vite-plugin-oss-one/issues"
  },
  "keywords": [
    "vite",
    "plugin",
    "vite-plugin",
    "oss",
    "upload",
    "aliyun",
    "ali-oss",
    "s3",
    "aws",
    "tencent",
    "cos",
    "qiniu",
    "upyun",
    "huawei",
    "obs",
    "baidu",
    "bos",
    "volcano",
    "tos",
    "google-cloud",
    "azure",
    "minio",
    "deploy"
  ],
  "license": "ISC",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./providers/aliyun": {
      "types": "./dist/providers/aliyun.d.ts",
      "import": "./dist/providers/aliyun.js",
      "require": "./dist/providers/aliyun.cjs"
    },
    "./providers/tencent": {
      "types": "./dist/providers/tencent.d.ts",
      "import": "./dist/providers/tencent.js",
      "require": "./dist/providers/tencent.cjs"
    },
    "./providers/s3": {
      "types": "./dist/providers/s3.d.ts",
      "import": "./dist/providers/s3.js",
      "require": "./dist/providers/s3.cjs"
    },
    "./providers/qiniu": {
      "types": "./dist/providers/qiniu.d.ts",
      "import": "./dist/providers/qiniu.js",
      "require": "./dist/providers/qiniu.cjs"
    },
    "./providers/upyun": {
      "types": "./dist/providers/upyun.d.ts",
      "import": "./dist/providers/upyun.js",
      "require": "./dist/providers/upyun.cjs"
    },
    "./providers/huawei": {
      "types": "./dist/providers/huawei.d.ts",
      "import": "./dist/providers/huawei.js",
      "require": "./dist/providers/huawei.cjs"
    },
    "./providers/baidu": {
      "types": "./dist/providers/baidu.d.ts",
      "import": "./dist/providers/baidu.js",
      "require": "./dist/providers/baidu.cjs"
    },
    "./providers/volcano": {
      "types": "./dist/providers/volcano.d.ts",
      "import": "./dist/providers/volcano.js",
      "require": "./dist/providers/volcano.cjs"
    },
    "./providers/google": {
      "types": "./dist/providers/google.d.ts",
      "import": "./dist/providers/google.js",
      "require": "./dist/providers/google.cjs"
    },
    "./providers/azure": {
      "types": "./dist/providers/azure.d.ts",
      "import": "./dist/providers/azure.js",
      "require": "./dist/providers/azure.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:examples": "node scripts/generate-examples.js && node scripts/test-examples.js"
  },
  "dependencies": {
    "cli-progress": "^3.12.0",
    "p-queue": "^8.0.1",
    "picocolors": "^1.0.0",
    "tinyglobby": "^0.2.10"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1008.0",
    "@azure/storage-blob": "^12.31.0",
    "@baiducloud/sdk": "^1.0.7",
    "@google-cloud/storage": "^7.19.0",
    "@types/ali-oss": "^6.16.0",
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^20.0.0",
    "@volcengine/tos-sdk": "^2.9.0",
    "ali-oss": "^6.23.0",
    "cos-nodejs-sdk-v5": "^2.15.4",
    "esdk-obs-nodejs": "^3.26.2",
    "pretty-bytes": "^7.1.0",
    "qiniu": "^7.15.1",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "upyun": "^3.4.6",
    "vite": "^5.0.0"
  }
}
